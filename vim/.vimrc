set tabstop=4
set shiftwidth=4
set smartindent
set expandtab
set number
set foldmethod=syntax
imap <S-Tab> <C-o><<
nmap <S-Left> <C-W><Left>
nmap <S-Right> <C-W><Right>
nmap <S-Up> <C-W><Up>
nmap <S-Down> <C-W><Down>

set modeline

syntax on
let javascript_enable_domhtmlcss=1 

set wildmode=longest,list

set history=1000
